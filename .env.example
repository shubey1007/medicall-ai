# Database
DATABASE_URL=postgresql+asyncpg://medicall:medicall@postgres:5432/medicall

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Twilio webhook BASE URL — the origin only, no path.
# Example: TWILIO_WEBHOOK_URL=https://abc123.ngrok-free.app
# The /twilio/incoming path is appended automatically.
TWILIO_WEBHOOK_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
POST_CALL_SUMMARY_MODEL=gpt-4o-mini

# Emergency escalation
ONCALL_PHONE_NUMBER=

# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Qdrant
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key

# Vapi
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER_ID=
PUBLIC_URL=https://your-ngrok-url.ngrok.io

# App
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
